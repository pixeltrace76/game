.creator-preview {
  min-height: 560rpx;
  padding: 78rpx 28rpx 36rpx;
  text-align: center;
}

.creator-preview .frog {
  width: 252rpx;
  height: 204rpx;
  transform: scale(1.08);
}

.preview-text {
  margin-top: 70rpx;
  font-size: 54rpx;
}

.form-block {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin: 0 0 14rpx 4rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.text-input {
  height: 92rpx;
  padding: 0 28rpx;
  border: 2rpx solid rgba(54, 131, 68, 0.16);
  border-radius: 16rpx;
  background: #fffdf5;
  font-size: 30rpx;
  font-weight: 800;
}

.mood-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.mood-pill {
  height: 72rpx;
  border-radius: 999rpx;
  color: #5e6d55;
  background: #fffdf5;
  border: 2rpx solid rgba(54, 131, 68, 0.12);
  font-size: 26rpx;
  font-weight: 800;
}

.mood-pill.active {
  color: #fff;
  background: #2f8f45;
}

.button-stack {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 360px;
  height: 360px;
}
