.home {
  position: relative;
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  padding: 0 28rpx 318rpx;
  background: #fcfcfc;
}

.stage {
  display: flex;
  min-height: calc(100vh - 318rpx);
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #fcfcfc;
  transform: translateZ(0);
}

.naiwa-idle {
  display: block;
  width: 82vw;
  height: 64vh;
  background: #fcfcfc;
  transform: translateZ(0);
}

.laugh-frame {
  position: relative;
  display: block;
  width: 76vw;
  height: 58vh;
  overflow: hidden;
  background: #fcfcfc;
  transform: translateZ(0);
}

.naiwa-laugh {
  display: block;
  width: 100%;
  height: 100%;
  background: #fcfcfc;
  transform: translateZ(0);
}

.stage.is-playing {
  animation: stage-shake 0.32s linear infinite;
}

@keyframes stage-shake {
  0% {
    transform: translate3d(0, 0, 0);
  }

  25% {
    transform: translate3d(-1rpx, 1rpx, 0);
  }

  50% {
    transform: translate3d(2rpx, -1rpx, 0);
  }

  75% {
    transform: translate3d(-1rpx, -1rpx, 0);
  }

  100% {
    transform: translate3d(0, 0, 0);
  }
}

.timer-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #fcfcfc;
}

.picker-lock {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  top: 10rpx;
  height: 210rpx;
  z-index: 5;
  background: rgba(253, 253, 253, 0);
}

.timer-picker {
  width: 100%;
  height: 210rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  transition: transform 180ms ease, background-color 180ms ease;
}

.timer-picker.is-moving {
  background: #f8f8f8;
  transform: translateY(-4rpx);
}

.picker-indicator {
  height: 70rpx;
  border-radius: 16rpx;
  background: rgba(17, 17, 17, 0.06);
}

.picker-item {
  display: flex;
  height: 70rpx;
  align-items: center;
  justify-content: center;
  color: #111111;
  font-weight: 900;
  letter-spacing: 0;
  opacity: 0.36;
  transform: scale(0.92);
  transition: transform 180ms ease, opacity 180ms ease, color 180ms ease;
}

.picker-item.active {
  opacity: 1;
  transform: scale(1);
}

.picker-number {
  min-width: 54rpx;
  text-align: right;
  font-size: 38rpx;
}

.picker-unit {
  margin-left: 8rpx;
  color: #777777;
  font-size: 26rpx;
  font-weight: 800;
  transition: color 180ms ease;
}

.picker-item.active .picker-unit {
  color: #111111;
}

.timer-button {
  display: flex;
  width: 100%;
  height: 104rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #ffffff;
  background: #111111;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.timer-button.counting {
  background: #d91f2b;
}
