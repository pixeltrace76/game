.sound-hero {
  padding: 34rpx 28rpx 30rpx;
  text-align: center;
}

.sound-hero .frog {
  transform: scale(0.9);
  transform-origin: center top;
}

.sound-title {
  display: block;
  margin-top: 2rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.sound-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6a725d;
  font-size: 26rpx;
}

.sound-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.sound-card {
  min-height: 190rpx;
  padding: 24rpx 18rpx;
  text-align: left;
}

.sound-card.playing {
  border-color: rgba(47, 143, 69, 0.48);
  background: #ecffdf;
}

.sound-name {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.sound-text {
  display: block;
  margin-top: 18rpx;
  color: #1d2b1a;
  font-size: 36rpx;
  font-weight: 900;
}

.sound-mood {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #2f8f45;
  background: #e9ffd9;
  font-size: 22rpx;
  font-weight: 800;
}
