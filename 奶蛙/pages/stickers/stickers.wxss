.category-scroll {
  position: sticky;
  z-index: 3;
  top: 0;
  width: 100%;
  white-space: nowrap;
  padding: 0 0 18rpx;
  background: #f7fff1;
}

.category-pill {
  display: inline-flex;
  min-width: 116rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #5e6d55;
  background: #fffdf5;
  font-size: 26rpx;
  font-weight: 800;
  border: 2rpx solid rgba(54, 131, 68, 0.12);
}

.category-pill.active {
  color: #fff;
  background: #2f8f45;
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.sticker-card {
  min-height: 348rpx;
  padding: 24rpx 16rpx 18rpx;
}

.sticker-card .frog {
  transform: scale(0.84);
  transform-origin: center top;
}

.sticker-card .sticker-text {
  margin-top: -4rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
  color: #6a725d;
  font-size: 22rpx;
  font-weight: 700;
}
